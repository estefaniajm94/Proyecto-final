<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen_base">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbarHome"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        android:elevation="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:itemIconTint="@color/brand_toolbar_icon"
        app:menu="@menu/menu_home_toolbar"
        app:navigationIconTint="@color/brand_toolbar_icon"
        app:subtitle="Offline-first | Privacidad por defecto"
        app:subtitleTextColor="#D9FFFFFF"
        app:title="Anti-phishing &amp; ciberfraude coach"
        app:titleTextColor="@android:color/white" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollHome"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbarHome">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_16">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardPrimaryAnalyze"
                style="@style/Widget.App.Card.Primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card_primary_gradient"
                android:clickable="true"
                android:focusable="true"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_card_primary_gradient"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_20">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <FrameLayout
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:background="@drawable/bg_icon_container">

                            <ImageView
                                android:id="@+id/ivPrimaryAnalyze"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:layout_gravity="center"
                                android:contentDescription="@null"
                                android:src="@android:drawable/ic_menu_search"
                                app:tint="@android:color/white" />
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/spacing_12"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                style="@style/TextAppearance.App.HeroTitle"
                                android:text="Analizar" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/spacing_4"
                                style="@style/TextAppearance.App.HeroBody"
                                android:text="Analiza SMS, email, chat o enlaces con heuristicas explicables." />
                        </LinearLayout>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_16"
                        android:background="@drawable/bg_info_pill"
                        android:paddingStart="@dimen/spacing_12"
                        android:paddingTop="@dimen/spacing_8"
                        android:paddingEnd="@dimen/spacing_12"
                        android:paddingBottom="@dimen/spacing_8"
                        android:text="Escanea enlaces y mensajes con contexto visual"
                        android:textColor="@android:color/white"
                        android:textSize="12sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPrimaryAnalyze"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_16"
                        android:textColor="@color/brand_primary_dark"
                        app:backgroundTint="@android:color/white"
                        android:text="ANALIZAR AHORA" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_20"
                style="@style/TextAppearance.App.SectionTitle"
                android:textColor="@android:color/white"
                android:text="Accesos rapidos" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_12">

                <androidx.constraintlayout.widget.Guideline
                    android:id="@+id/guidelineGridHalf"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    app:layout_constraintGuide_percent="0.5" />

                <include
                    android:id="@+id/cardQuickCoach"
                    layout="@layout/view_home_action_card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    app:layout_constraintEnd_toStartOf="@id/guidelineGridHalf"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <include
                    android:id="@+id/cardQuickTraining"
                    layout="@layout/view_home_action_card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_12"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="@id/guidelineGridHalf"
                    app:layout_constraintTop_toTopOf="parent" />

                <include
                    android:id="@+id/cardQuickHistory"
                    layout="@layout/view_home_action_card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_12"
                    app:layout_constraintEnd_toStartOf="@id/guidelineGridHalf"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/cardQuickCoach" />

                <include
                    android:id="@+id/cardQuickResources"
                    layout="@layout/view_home_action_card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_12"
                    android:layout_marginTop="@dimen/spacing_12"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="@id/guidelineGridHalf"
                    app:layout_constraintTop_toBottomOf="@id/cardQuickTraining" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_24"
                style="@style/TextAppearance.App.SectionTitle"
                android:text="Actividad" />

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.App.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_12">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <View
                        android:id="@+id/viewLatestSeverityBar"
                        android:layout_width="match_parent"
                        android:layout_height="4dp"
                        android:background="@drawable/bg_severity_bar_green" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_16">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            style="@style/TextAppearance.App.SectionTitle"
                            android:text="Ultimo analisis" />

                        <ProgressBar
                            android:id="@+id/progressLatestIncident"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_12"
                            android:visibility="gone" />

                        <LinearLayout
                            android:id="@+id/layoutLatestIncidentEmpty"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_12"
                            android:gravity="center_horizontal"
                            android:orientation="vertical"
                            android:visibility="gone">

                            <ImageView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:contentDescription="@null"
                                android:src="@android:drawable/ic_dialog_info"
                                app:tint="@color/brand_primary_dark" />

                            <TextView
                                android:id="@+id/tvLatestAnalysisEmpty"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/spacing_8"
                                android:gravity="center"
                                style="@style/TextAppearance.App.CardBody"
                                android:text="Aun no hay analisis guardados" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnAnalyzeFromLatestEmpty"
                                style="@style/Widget.App.Button.Outline"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/spacing_12"
                                android:text="Ir a Analizar" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/layoutLatestIncidentData"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_12"
                            android:orientation="vertical"
                            android:visibility="gone">

                            <TextView
                                android:id="@+id/tvLatestTitle"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                style="@style/TextAppearance.App.CardTitle"
                                android:text="Analisis sin titulo" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/spacing_8"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <com.google.android.material.chip.Chip
                                    android:id="@+id/chipLatestTraffic"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textColor="@android:color/white" />

                                <TextView
                                    android:id="@+id/tvLatestScore"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="@dimen/spacing_12"
                                    android:text="0/100"
                                    android:textSize="28sp"
                                    android:textStyle="bold" />
                            </LinearLayout>

                            <TextView
                                android:id="@+id/tvLatestDate"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/spacing_8"
                                style="@style/TextAppearance.App.CardBody"
                                android:text="Fecha" />

                            <TextView
                                android:id="@+id/tvLatestDomain"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/spacing_4"
                                style="@style/TextAppearance.App.CardBody"
                                android:visibility="gone" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnLatestAnalysisDetail"
                                style="@style/Widget.App.Button.Outline"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/spacing_12"
                                android:text="VER DETALLE" />
                        </LinearLayout>

                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.App.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_16">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_16">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        style="@style/TextAppearance.App.SectionTitle"
                        android:text="Ultimo entrenamiento" />

                    <LinearLayout
                        android:id="@+id/layoutLatestTrainingEmpty"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_12"
                        android:gravity="center_horizontal"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:contentDescription="@null"
                            android:src="@android:drawable/ic_menu_agenda"
                            app:tint="@color/brand_primary_dark" />

                        <TextView
                            android:id="@+id/tvLatestTrainingSummary"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_8"
                            android:gravity="center"
                            style="@style/TextAppearance.App.CardBody" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnRepeatTraining"
                            style="@style/Widget.App.Button.Outline"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_12"
                            android:text="EMPEZAR QUIZ" />
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_24"
                android:text="@string/disclaimer_main"
                style="@style/TextAppearance.App.CardBody" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
