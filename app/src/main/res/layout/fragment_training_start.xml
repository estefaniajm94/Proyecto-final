<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen_base">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@android:color/transparent"
                android:contentDescription="@string/navigation_back"
                android:padding="8dp"
                android:src="@drawable/ic_arrow_back_24"
                android:tint="@android:color/white" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="@string/screen_title_training"
                android:textAppearance="@style/TextAppearance.App.ToolbarTitle" />
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.App.Card.Primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card_primary_gradient"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:id="@+id/tvTrainingLoading"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/training_loading"
                    android:textColor="@android:color/white"
                    android:visibility="gone" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/training_level_selector_title"
                    android:textAppearance="@style/TextAppearance.App.HeroTitle" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/training_level_selector_subtitle"
                    android:textAppearance="@style/TextAppearance.App.HeroBody" />

                <TextView
                    android:id="@+id/tvTotalQuestions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:textColor="@android:color/white"
                    android:textSize="20sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.App.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/training_choose_level"
                    android:textAppearance="@style/TextAppearance.App.SectionTitle" />

                <com.google.android.material.button.MaterialButtonToggleGroup
                    android:id="@+id/toggleTrainingLevels"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    app:selectionRequired="true"
                    app:singleSelection="true">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnLevelBeginner"
                        style="@style/Widget.App.Button.Outline"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/training_level_beginner" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnLevelIntermediate"
                        style="@style/Widget.App.Button.Outline"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/training_level_intermediate" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnLevelAdvanced"
                        style="@style/Widget.App.Button.Outline"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/training_level_advanced" />
                </com.google.android.material.button.MaterialButtonToggleGroup>

                <TextView
                    android:id="@+id/tvSelectedLevelTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:textAppearance="@style/TextAppearance.App.CardTitle" />

                <TextView
                    android:id="@+id/tvSelectedLevelDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textAppearance="@style/TextAppearance.App.CardBody" />

                <TextView
                    android:id="@+id/tvSelectedLevelCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_info_pill"
                    android:paddingLeft="12dp"
                    android:paddingTop="6dp"
                    android:paddingRight="12dp"
                    android:paddingBottom="6dp"
                    android:textColor="@color/brand_on_surface" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnStartQuiz"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="@string/training_start_button" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</ScrollView>
