<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/Widget.App.Card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center_horizontal"
        android:minHeight="120dp"
        android:orientation="vertical"
        android:padding="@dimen/spacing_16">

        <FrameLayout
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_icon_container">

            <ImageView
                android:id="@+id/ivActionIcon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center"
                android:contentDescription="@null"
                app:tint="@color/brand_primary_dark" />
        </FrameLayout>

        <TextView
            android:id="@+id/tvActionTitle"
            style="@style/TextAppearance.App.CardTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_8"
            android:gravity="center"
            android:text="Titulo" />

        <TextView
            android:id="@+id/tvActionDescription"
            style="@style/TextAppearance.App.CardBody"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_8"
            android:gravity="center"
            android:text="Descripcion breve" />
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
