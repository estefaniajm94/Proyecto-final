<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.AntiPhishingCoach" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/brand_primary</item>
        <item name="colorOnPrimary">@color/brand_on_primary</item>
        <item name="colorSecondary">@color/brand_secondary</item>
        <item name="android:colorBackground">@color/brand_background</item>
        <item name="colorSurface">@color/brand_surface</item>
        <item name="colorOnSurface">@color/brand_on_surface</item>
        <item name="android:statusBarColor" tools:targetApi="l">@android:color/transparent</item>
        <item name="android:windowBackground">@drawable/bg_screen_base</item>
        <item name="materialButtonStyle">@style/Widget.App.Button</item>
        <item name="chipStyle">@style/Widget.App.Chip</item>
    </style>

    <style name="Widget.App.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">@dimen/radius_24</item>
        <item name="cardElevation">8dp</item>
        <item name="strokeColor">@color/card_outline_soft</item>
        <item name="strokeWidth">1dp</item>
        <item name="cardBackgroundColor">@color/brand_surface</item>
    </style>

    <style name="Widget.App.Card.Primary" parent="Widget.App.Card">
        <item name="cardBackgroundColor">@android:color/transparent</item>
    </style>

    <style name="TextAppearance.App.ToolbarTitle" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="android:textSize">26sp</item>
    </style>

    <style name="TextAppearance.App.SectionTitle" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/brand_on_surface</item>
    </style>

    <style name="TextAppearance.App.CardTitle" parent="TextAppearance.MaterialComponents.Subtitle1">
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/brand_on_surface</item>
    </style>

    <style name="TextAppearance.App.CardBody" parent="TextAppearance.MaterialComponents.Body2">
        <item name="android:textColor">@color/brand_on_surface_soft</item>
    </style>

    <style name="TextAppearance.App.HeroTitle" parent="TextAppearance.MaterialComponents.Headline4">
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@android:color/white</item>
    </style>

    <style name="TextAppearance.App.HeroBody" parent="TextAppearance.MaterialComponents.Body2">
        <item name="android:textColor">#E6FFFFFF</item>
    </style>

    <style name="Widget.App.Button" parent="Widget.MaterialComponents.Button">
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">@dimen/radius_24</item>
        <item name="backgroundTint">@color/brand_secondary</item>
        <item name="android:textColor">@color/brand_on_surface</item>
        <item name="rippleColor">@color/brand_secondary_soft</item>
        <item name="elevation">0dp</item>
        <item name="android:minHeight">52dp</item>
    </style>

    <style name="Widget.App.Button.Outline" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">@dimen/radius_24</item>
        <item name="strokeColor">@color/card_outline_soft</item>
        <item name="strokeWidth">1dp</item>
        <item name="android:textColor">@color/brand_primary</item>
        <item name="backgroundTint">@color/brand_surface</item>
        <item name="android:minHeight">52dp</item>
    </style>

    <style name="Widget.App.Chip" parent="Widget.MaterialComponents.Chip.Entry">
        <item name="chipCornerRadius">@dimen/radius_18</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.App.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundMode">outline</item>
        <item name="boxCornerRadiusTopStart">@dimen/radius_18</item>
        <item name="boxCornerRadiusTopEnd">@dimen/radius_18</item>
        <item name="boxCornerRadiusBottomStart">@dimen/radius_18</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/radius_18</item>
        <item name="boxStrokeColor">@color/card_outline_soft</item>
        <item name="hintTextColor">@color/brand_on_surface_soft</item>
        <item name="android:textColorHint">@color/brand_on_surface_soft</item>
    </style>

    <style name="Widget.App.DropdownTextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu">
        <item name="boxBackgroundMode">outline</item>
        <item name="boxCornerRadiusTopStart">@dimen/radius_18</item>
        <item name="boxCornerRadiusTopEnd">@dimen/radius_18</item>
        <item name="boxCornerRadiusBottomStart">@dimen/radius_18</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/radius_18</item>
        <item name="boxStrokeColor">@color/card_outline_soft</item>
        <item name="hintTextColor">@color/brand_on_surface_soft</item>
        <item name="android:textColorHint">@color/brand_on_surface_soft</item>
    </style>
</resources>
