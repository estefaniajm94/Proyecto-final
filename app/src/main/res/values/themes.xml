<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.AntiPhishingCoach" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/brand_primary</item>
        <item name="colorOnPrimary">@color/brand_on_primary</item>
        <item name="colorSecondary">@color/brand_secondary</item>
        <item name="android:colorBackground">@color/brand_background</item>
        <item name="colorSurface">@color/brand_surface</item>
        <item name="colorOnSurface">@color/brand_on_surface</item>
        <item name="android:statusBarColor" tools:targetApi="l">@color/brand_primary</item>
    </style>

    <style name="Widget.App.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">@dimen/radius_16</item>
        <item name="cardElevation">2dp</item>
        <item name="strokeColor">@color/card_outline_soft</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="Widget.App.Card.Primary" parent="Widget.App.Card">
        <item name="cardBackgroundColor">@color/home_primary_card</item>
    </style>

    <style name="TextAppearance.App.SectionTitle" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.App.CardTitle" parent="TextAppearance.MaterialComponents.Subtitle1">
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.App.CardBody" parent="TextAppearance.MaterialComponents.Body2">
        <item name="android:textColor">@color/brand_on_surface_soft</item>
    </style>
</resources>
